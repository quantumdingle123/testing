local function applyTrans(val)
    val = math.clamp(val, 0, 100)
    local a = val / 100
    sldrTxt.Text = "Transparency: " .. math.floor(val) .. "%"
    sldrFil.Size = UDim2.new(a, 0, 1, 0)
    sldrKn.Position = UDim2.new(a, -7, 0.5, -7)

    local function doT(inst)
        if inst:IsA("GuiObject") then
            if inst:GetAttribute("OrigBg") == nil then inst:SetAttribute("OrigBg", inst.BackgroundTransparency) end
            inst.BackgroundTransparency = inst:GetAttribute("OrigBg") + ((1 - inst:GetAttribute("OrigBg")) * (a * 0.90))
        end
        if inst:IsA("TextLabel") or inst:IsA("TextButton") or inst:IsA("TextBox") then
            if inst:GetAttribute("OrigTxt") == nil then inst:SetAttribute("OrigTxt", inst.TextTransparency) end
            inst.TextTransparency = inst:GetAttribute("OrigTxt") + ((1 - inst:GetAttribute("OrigTxt")) * (a * 0.2))
        end
        if inst:IsA("UIStroke") then
            if inst:GetAttribute("OrigStr") == nil then inst:SetAttribute("OrigStr", inst.Transparency) end
            inst.Transparency = inst:GetAttribute("OrigStr") + ((1 - inst:GetAttribute("OrigStr")) * (a * 0.4))
        end
    end

    doT(frm)
    for _, child in ipairs(frm:GetDescendants()) do doT(child) end
end

