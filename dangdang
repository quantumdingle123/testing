local function doParry()
    local now = os.clock()
    if (now - getgenv().LastParryTime) < parryWait then return end
    getgenv().LastParryTime = now
    
    task.spawn(function()
        pcall(function()
            local oldIdentity = getthreadidentity()
            setthreadidentity(2)
            
            local WarpModule = game:GetService("ReplicatedStorage"):WaitForChild("Modules"):WaitForChild("Warp"):WaitForChild("Index")
            local Warp = require(WarpModule)
            
            local remoteEvent = Warp.Client("Input")
            remoteEvent:Fire(true, { "Ability", 2 })
            
            setthreadidentity(oldIdentity)
        end)
    end)
end

local function setupEnemy(chr)
    if chr == me.Character then return end
    local hum = chr:WaitForChild("Humanoid", 5)
    local anim = hum and hum:WaitForChild("Animator", 5)
    if not anim then return end

    anim.AnimationPlayed:Connect(function(track)
        if not getgenv().AutoParryEnabled then return end
        if (os.clock() - getgenv().LastParryTime) < parryWait then return end
        
        local a = track.Animation; if not a then return end
        local id = string.match(a.AnimationId, "%d+")
        local base = atkRanges[id]
        
        if base then
            if me.Character and me.Character:FindFirstChild("HumanoidRootPart") then
                local eRoot = chr:FindFirstChild("HumanoidRootPart")
                local mRoot = me.Character.HumanoidRootPart
                if not eRoot then return end
                
                local dist = (mRoot.Position - eRoot.Position).Magnitude
                if dist <= (base + pingPad) then doParry() end
            end
        end
    end)
end

