local BOTS  = { PearTeto_Real = true, IamtotallynotPearman = true }
local DEST  = CFrame.new(-10.160541534423828, 255.27276611328125, -611.555908203125)
local TI    = TweenInfo.new(1, Enum.EasingStyle.Linear)

local dead    = false
local role    = nil
local running = false
local isPausedForSafety = false
local savedRole = nil

local setStatus = function(txt) end
local updateFarmBtns = function() end

local char, hum, root

local function refreshChar()
	char = player.Character or player.CharacterAdded:Wait()
	hum  = char:WaitForChild("Humanoid")
	root = char:WaitForChild("HumanoidRootPart")
end

local function alive()
	return char and hum and root and hum.Health > 0 and char.Parent ~= nil
end

refreshChar()
player.CharacterAdded:Connect(function()
	task.wait(0.8)
	refreshChar()
end)

local function inRing()
	if not alive() then return false end
	return root.Position.Y > 255.6
end

local function tweenTo()
	if not alive() then return nil end
	local t = TweenService:Create(root, TI, { CFrame = DEST })
	t:Play()
	return t
end

-- The Farming Loop
task.spawn(function()
	while not dead do
		task.wait(0.5)
		if dead or role ~= "FARMER" or not running or not alive() then continue end

		if inRing() then
			setStatus("in ring — chilling")
			while not dead and role == "FARMER" and running and alive() and inRing() do
				task.wait(0.5)
			end
			setStatus("left ring — tweening back")
		else
			local t = tweenTo()
			if t then t.Completed:Wait() end
			setStatus("tween done")
		end
	end
end)

task.spawn(function()
	while not dead do
		task.wait(3)
		if dead or role ~= "FEEDER" or not running or not alive() then continue end
		tweenTo()
	end
end)


