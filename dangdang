local isOpen = true
local openSize = mainFrame.Size

local function openGui()
	mainFrame.Visible = true
	glowHolder.Visible = true
	mainFrame.Size = UDim2.new(0, 0, 0, 0)
	glowHolder.Size = UDim2.new(0, 0, 0, 0)

	tweenObject(mainFrame, tweenSmooth, {Size = openSize})
	tweenObject(glowHolder, tweenSmooth, {Size = UDim2.new(0, 760, 0, 520)})

	toggleButton.Text = "Close"
	isOpen = true
end

local function closeGui()
	local closeTween = tweenObject(mainFrame, tweenSmooth, {Size = UDim2.new(0, 0, 0, 0)})
	tweenObject(glowHolder, tweenSmooth, {Size = UDim2.new(0, 0, 0, 0)})

	closeTween.Completed:Connect(function()
		if not isOpen then
			mainFrame.Visible = false
			glowHolder.Visible = false
		end
	end)

	toggleButton.Text = "Open"
	isOpen = false
end

toggleButton.MouseButton1Click:Connect(function()
	local baseSize = mobileMode and UDim2.new(0, 130, 0, 50) or UDim2.new(0, 120, 0, 44)

	tweenObject(toggleButton, tweenFast, {
		Size = UDim2.new(baseSize.X.Scale, baseSize.X.Offset - 4, baseSize.Y.Scale, baseSize.Y.Offset - 4)
	})

	task.delay(0.08, function()
		tweenObject(toggleButton, tweenFast, {Size = baseSize})
	end)

	if isOpen then
		isOpen = false
		closeGui()
	else
		openGui()
	end
end)

