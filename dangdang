local function hopServer()
    if isHopping then return end
    isHopping = true
    sendNotif("Server Hopping", "Finding a server with more players...")
    
    local req = request or http_request or (syn and syn.request) or (fluxus and fluxus.request)
    if req then
        pcall(function()
            local res = req({
                Url = "https://games.roblox.com/v1/games/" .. tostring(game.PlaceId) .. "/servers/Public?sortOrder=Desc&limit=100",
                Method = "GET"
            })
            if res and res.Body then
                local data = http:JSONDecode(res.Body)
                if data and data.data then
                    for _, v in ipairs(data.data) do
                        if type(v) == "table" and v.playing and v.playing > 2 and v.playing < v.maxPlayers and v.id ~= game.JobId then
                            tps:TeleportToPlaceInstance(game.PlaceId, v.id, me)
                            return
                        end
                    end
                end
            end
        end)
    end
    tps:Teleport(game.PlaceId, me)
end

