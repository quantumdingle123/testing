local nativeFireServer = Instance.new("RemoteEvent").FireServer

local function getSmartTarget()
    local mPos = getAimCenter()
    local closestDistance = getgenv().SilentAimFOV
    local closestTarget = nil
    
    local function checkTarget(char)
        if char and char ~= me.Character then
            local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Head") or char.PrimaryPart
            if root then
                local screenPos, onScreen = camera:WorldToScreenPoint(root.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mPos).Magnitude
                    if dist <= closestDistance then
                        closestDistance = dist
                        closestTarget = root
                    end
                end
            end
        end
    end

    local killerFolder = workspace:FindFirstChild("KILLER")
    if killerFolder then
        for _, char in ipairs(killerFolder:GetChildren()) do 
            checkTarget(char) 
        end
    end
    
    if closestTarget then return closestTarget end 

    for _, player in ipairs(plrs:GetPlayers()) do
        if player ~= me then 
            local hum = player.Character and player.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                checkTarget(player.Character) 
            end
        end
    end
    
    return closestTarget
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    
    if not checkcaller() and getgenv().SilentAimEnabled and typeof(self) == "Instance" then
        if method == "FireServer" and self.Name == "Request" then
            local args = {...}
            if typeof(args[1]) == "buffer" and type(args[3]) == "table" then
                if type(args[3][1]) == "table" and type(args[3][1][2]) == "table" then
                    if typeof(args[3][1][2][1]) == "CFrame" then
                        local targetHRP = getSmartTarget()
                        if targetHRP then
                            local originalPosition = args[3][1][2][1].Position
                            args[3][1][2][1] = CFrame.lookAt(originalPosition, targetHRP.Position)
                            return nativeFireServer(self, unpack(args))
                        end
                    end
                end
            end
        end
    end
    
    return oldNamecall(self, ...)
end)

local function getPromptPos(prmpt, obj)
    if prmpt and prmpt.Parent then
        if prmpt.Parent:IsA("Attachment") then return prmpt.Parent.WorldPosition end
        if prmpt.Parent:IsA("BasePart") then return prmpt.Parent.Position end
    end
    if obj and (obj:IsA("Model") or obj:IsA("BasePart")) then return obj:GetPivot().Position end
    return nil
end

local function getClosestObj(charPos)
    local bPrompt, bPos, bObj = nil, nil, nil
    local bDist = math.huge
    
    if getgenv().AutoGenEnabled then
        for obj, _ in pairs(cache.Gens) do
            local p = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if p and p.Enabled then
                local pos = getPromptPos(p, obj)
                if pos then
                    local d = (charPos - pos).Magnitude
                    if d < bDist then bDist = d; bPrompt = p; bPos = pos; bObj = obj end
                end
            end
        end
    end
    return bPrompt, bPos, bObj
end

getgenv().MyAutoGenLoop = task.spawn(function()
    local function flyTo(hrp, hum, startPos, endPos, speed)
        local dist = (startPos - endPos).Magnitude
        if dist < 0.5 then return true end
        local travelTime = dist / speed
        local bv = hrp:FindFirstChild("SafeHover") or Instance.new("BodyVelocity")
        bv.Name = "SafeHover"; bv.Velocity = Vector3.zero; bv.MaxForce = Vector3.new(1e5, 1e5, 1e5); bv.Parent = hrp
        hum.PlatformStand = true; hrp.Anchored = false 
        
        local st = os.clock(); local conn; local ok = true
        conn = rs.Heartbeat:Connect(function()
            if not getgenv().AutoGenEnabled or hum.Health <= 0 or not hrp.Parent then
                ok = false; conn:Disconnect(); return
            end
            local a = math.clamp((os.clock() - st) / travelTime, 0, 1)
            hrp.CFrame = CFrame.new(startPos:Lerp(endPos, a)); hrp.Velocity = Vector3.zero 
            if a >= 1 then conn:Disconnect() end
        end)
        while conn.Connected do task.wait() end
        if bv then bv:Destroy() end
        return ok
    end

    while true do
        task.wait(0.2) 
        pcall(function()
            if getgenv().AutoGenEnabled then
                
                if #plrs:GetPlayers() <= 2 then hopServer(); task.wait(5); return end
                
                local c = me.Character
                if not c or not c.Parent then return end 
                local hrp = c:FindFirstChild("HumanoidRootPart")
                local hum = c:FindFirstChild("Humanoid")
                
                if hrp and hum and hum.Health > 0 then
                    
                    if inSafeZone(hrp.Position) then 
                        getgenv().ShouldBlackScreen = false
                        if blockScreen then blockScreen.Enabled = false end
                        c:SetAttribute("EnterGameTime", nil)
                        goSurface()
                        return 
                    else
                        getgenv().ShouldBlackScreen = true
                        if blockScreen then blockScreen.Enabled = true end
                    end
                    
                    local enterTime = c:GetAttribute("EnterGameTime")
                    if not enterTime then c:SetAttribute("EnterGameTime", os.clock()); return end
                    if os.clock() - enterTime < 2 then return end

                    if not getgenv().NoclipConnection then
                        getgenv().NoclipConnection = rs.Stepped:Connect(function()
                            if me.Character then for _, part in ipairs(me.Character:GetDescendants()) do if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end end end
                        end)
                    end

                    local nPrompt, tPos, tObj = getClosestObj(hrp.Position)
                    
                    if not nPrompt then 
                        getgenv().ShouldBlackScreen = false
                        if blockScreen then blockScreen.Enabled = false end

                        goSurface()
                        if getgenv().AutoGenEnabled and hum.Health > 0 then
                            hum.Health = 0
                            task.wait(3) 
                        end
                        return 
                    end

                    local depth = 9
                    local under = tPos - Vector3.new(0, depth, 0)
                    local hDist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(under.X, 0, under.Z)).Magnitude
                    
                    if hDist > 5 then
                        if not getgenv().IsUnderground then
                            flyTo(hrp, hum, hrp.Position, hrp.Position - Vector3.new(0, depth, 0), 50); getgenv().IsUnderground = true
                        end
                        if not flyTo(hrp, hum, hrp.Position, Vector3.new(under.X, hrp.Position.Y, under.Z), 24) then return end
                    end
                    
                    spawnPlat(under)
                    getgenv().SafeToBypass = false 
                    getgenv().IsUnderground = true
                    
                    local opened = false
                    local tOut = 0
                    
                    while tOut < 60 do 
                        local gUi = me:FindFirstChild("PlayerGui") and me.PlayerGui:FindFirstChild("Gen")
                        if gUi and gUi.Enabled then opened = true; break end
                        
                        hrp.CFrame = CFrame.new(under); hrp.Velocity = Vector3.zero
                        
                        for _, p in ipairs(tObj:GetDescendants()) do
                            if p:IsA("ProximityPrompt") and p.Enabled then
                                p.HoldDuration = 0; p.MaxActivationDistance = 99999; p.RequiresLineOfSight = false
                                if fireproximityprompt then fireproximityprompt(p) end
                            end
                        end
                        task.wait(0.05); tOut = tOut + 1
                    end
                    
                    if opened then
                        hrp.CFrame = CFrame.new(under); hrp.Anchored = false; getgenv().IsUnderground = true
                        getgenv().SafeToBypass = true 
                        while getgenv().AutoGenEnabled and hum.Health > 0 do
                            local gUi = me:FindFirstChild("PlayerGui") and me.PlayerGui:FindFirstChild("Gen")
                            if not gUi or not gUi.Enabled or not nPrompt or not nPrompt.Parent or not nPrompt.Enabled then break end
                            hrp.CFrame = CFrame.new(under); hrp.Velocity = Vector3.zero; task.wait(0.1)
                        end
                        getgenv().SafeToBypass = false; task.wait(0.5) 
                    end
                end
            end
        end)
    end
end)

