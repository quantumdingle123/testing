getgenv().MyESPLoop = task.spawn(function()
    local camera = workspace.CurrentCamera

    while true do
        task.wait(0.5) 
        pcall(function()
            local cPos = camera.CFrame.Position 
            local rQueue = {}
            
            local function qTarg(t, n, col, isK)
                if t then
                    local p = t:IsA("Model") and t:GetPivot().Position or t.Position
                    table.insert(rQueue, {Target = t, Name = n, Color = col, Dist = (p - cPos).Magnitude, IsK = isK})
                end
            end

            for t, h in pairs(activeHls) do
                local shouldKeep = true
                
                if not t or not t.Parent then 
                    shouldKeep = false 
                elseif h.Name == "KillerESP" and not getgenv().ESPToggles.Killer then
                    shouldKeep = false
                elseif h.Name == "TrapESP" and not getgenv().ESPToggles.Killer then 
                    shouldKeep = false 
                elseif h.Name == "GenESP" and not getgenv().ESPToggles.Generator then
                    shouldKeep = false
                elseif h.Name == "BatESP" and not getgenv().ESPToggles.Battery then
                    shouldKeep = false
                elseif h.Name == "FuseESP" and not getgenv().ESPToggles.Fusebox then
                    shouldKeep = false
                elseif h.Name == "PlrESP" and not getgenv().ESPToggles.Players then
                    shouldKeep = false
                end

                if not shouldKeep then
                    h:Destroy()
                    activeHls[t] = nil 
                else
                    h.Enabled = false 
                end
            end
            
            for t, d in pairs(activeDots) do
                if not t or not t.Parent or not getgenv().ESPToggles.Killer then 
                    d:Destroy()
                    activeDots[t] = nil 
                else 
                    d.Enabled = false 
                end
            end

            if getgenv().ESPToggles.Killer then
                local kFold = workspace:FindFirstChild("KILLER")
                if kFold then 
                    for _, ch in ipairs(kFold:GetChildren()) do 
                        if ch:IsA("Model") then qTarg(ch, "KillerESP", cKill, true) end 
                    end 
                end
                
                if not getgenv().LockedKillerName then
                    for _, p in ipairs(plrs:GetPlayers()) do
                        if p == me then continue end 
                        if p.Character then 
                            for _, ch in ipairs(p.Character:GetChildren()) do 
                                if string.find(string.lower(ch.Name), "killer") then 
                                    getgenv().LockedKillerName = p.Name
                                    break 
                                end 
                            end 
                        end
                    end
                else
                    local lkPlr = plrs:FindFirstChild(getgenv().LockedKillerName)
                    local isK = false
                    if lkPlr and lkPlr.Character then
                        for _, ch in ipairs(lkPlr.Character:GetChildren()) do 
                            if string.find(string.lower(ch.Name), "killer") then 
                                isK = true
                                break 
                            end 
                        end
                    end
                    if isK then 
                        qTarg(lkPlr.Character, "KillerESP", cKill, true) 
                    else 
                        getgenv().LockedKillerName = nil 
                    end
                end
                
                for obj, _ in pairs(cache.Traps) do 
                    if obj.Parent then 
                        qTarg(obj, "TrapESP", cTrap, false)
                    end
                end
            end

            if getgenv().ESPToggles.Battery then 
                for obj, _ in pairs(cache.Bats) do 
                    if obj:FindFirstChildWhichIsA("ProximityPrompt", true) then qTarg(obj, "BatESP", cBat) end 
                end 
            end
            
            if getgenv().ESPToggles.Fusebox then 
                for obj, _ in pairs(cache.Fuses) do 
                    if obj:FindFirstChildWhichIsA("ProximityPrompt", true) then qTarg(obj, "FuseESP", cFuse) end 
                end 
            end
            
            if getgenv().ESPToggles.Generator then
                for obj, _ in pairs(cache.Gens) do
                    if obj:FindFirstChildWhichIsA("ProximityPrompt", true) then
                        local dn = true
                        for _, ch in ipairs(obj:GetDescendants()) do 
                            if ch:IsA("ProximityPrompt") and ch.Enabled then 
                                dn = false 
                                break 
                            end 
                        end
                        qTarg(obj, "GenESP", dn and cDone or cNotDone)
                    end
                end
            end
            
            if getgenv().ESPToggles.Players then
                for _, p in ipairs(plrs:GetPlayers()) do
                    if p == me or not p.Character then continue end
                    if getgenv().LockedKillerName ~= p.Name then qTarg(p.Character, "PlrESP", cPlr) end
                end
            end

            table.sort(rQueue, function(a, b) return a.Dist < b.Dist end)
            
            for i = 1, math.min(#rQueue, 28) do
                local it = rQueue[i]
                makeHighlight(it.Target, it.Name, it.Color)
                if it.IsK then makeKillerDot(it.Target) end
            end
        end)
    end
end)

