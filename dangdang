local function inSafeZone(pos) 
    for _, zone in ipairs(safeZones) do
        if math.abs(pos.X - zone.Center.X) <= zone.Radius and 
           math.abs(pos.Y - zone.Center.Y) <= zone.Radius and 
           math.abs(pos.Z - zone.Center.Z) <= zone.Radius then
            return true 
        end
    end
    return false 
end

